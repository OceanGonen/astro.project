---
// @ts-nocheck

const player = Astro.url.searchParams.get("player");

let games = [];
let error = null;
let bestGame = null;
let worstGame = null;
let timeline = [];
let firstDate = null;
let lastDate = null;

function extractGames(raw) {
  return raw.map((game) => ({
    id: game.id,
    createdAt: game.createdAt,
    winner: game.winner ?? "draw",
    white: {
      user: game.players.white.user?.id,
      rating: game.players.white.rating,
      accuracy: game.players.white.analysis?.accuracy ?? null,
    },
    black: {
      user: game.players.black.user?.id,
      rating: game.players.black.rating,
      accuracy: game.players.black.analysis?.accuracy ?? null,
    },
  }));
}

function groupGamesByRating(games, username) {
  const groups = {};
  games.forEach((game) => {
    const isWhite = game.white.user?.toLowerCase() === username.toLowerCase();
    const isBlack = game.black.user?.toLowerCase() === username.toLowerCase();
    if (!isWhite && !isBlack) return;

    const userRating   = isWhite ? game.white.rating   : game.black.rating;
    const userAccuracy = isWhite ? game.white.accuracy  : game.black.accuracy;
    const opponent     = isWhite
      ? { name: game.black.user, rating: game.black.rating, accuracy: game.black.accuracy }
      : { name: game.white.user, rating: game.white.rating, accuracy: game.white.accuracy };

    if (!groups[userRating]) groups[userRating] = [];
    groups[userRating].push({
      id: game.id,
      rating: userRating,
      accuracy: userAccuracy,
      winner: game.winner ?? "draw",
      color: isWhite ? "white" : "black",
      date: game.createdAt,
      opponent,
    });
  });
  return groups;
}

function findAccuracyExtremes(grouped) {
  const results = {};
  for (const rating in grouped) {
    const withAcc = grouped[rating].filter((g) => g.accuracy !== null);
    if (!withAcc.length) { results[rating] = { highest: null, lowest: null }; continue; }
    results[rating] = {
      highest: withAcc.reduce((a, b) => b.accuracy > a.accuracy ? b : a),
      lowest:  withAcc.reduce((a, b) => b.accuracy < a.accuracy ? b : a),
    };
  }
  return results;
}

function createTimeline(games, username) {
  return games
    .map((game) => {
      const isWhite = game.white.user?.toLowerCase() === username.toLowerCase();
      const isBlack = game.black.user?.toLowerCase() === username.toLowerCase();
      if (!isWhite && !isBlack) return null;
      return { date: game.createdAt, rating: isWhite ? game.white.rating : game.black.rating };
    })
    .filter(Boolean)
    .sort((a, b) => a.date - b.date);
}

function getResult(game) {
  if (game.winner === "draw") return "½ Draw";
  return game.winner === game.color ? "Win" : "Loss";
}

if (player) {
  try {
    const response = await fetch(
      `https://lichess.org/api/games/user/${player}?perfType=rapid&analysed=true&accuracy=true`,
      { headers: { Accept: "application/x-ndjson" } }
    );

    if (!response.ok) throw new Error(`Lichess API error: ${response.status}`);

    const text = await response.text();
    const raw  = text.trim().split("\n").filter(Boolean).map((l) => JSON.parse(l));
    games      = extractGames(raw);

    const grouped  = groupGamesByRating(games, player);
    const analysis = findAccuracyExtremes(grouped);
    timeline       = createTimeline(games, player);

    for (const rating in analysis) {
      const { highest, lowest } = analysis[rating];
      if (highest && (!bestGame  || highest.accuracy > bestGame.accuracy))
        bestGame  = { ...highest, rating };
      if (lowest  && (!worstGame || lowest.accuracy  < worstGame.accuracy))
        worstGame = { ...lowest,  rating };
    }

    if (games.length) {
      firstDate = new Date(Math.min(...games.map((g) => g.createdAt))).toLocaleDateString("en-GB");
      lastDate  = new Date(Math.max(...games.map((g) => g.createdAt))).toLocaleDateString("en-GB");
    }

  } catch (e) {
    error = e.message;
  }
}

// Safely serialize for client — define:vars handles the escaping
const timelineData = timeline;
const allGamesData = games;
  
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ChessLens</title>
    <link rel="stylesheet" href="/src/styles/style.css" />
  </head>
  <body>


    <form method="GET" action="/">
      <div class="header-row">

        <h1>ChessLens</h1>
      <div class="input-row">

        <label for="player">LiChess username</label>
        <input
          type="text"
          id="player"
          name="player"
          placeholder="Enter username"
          value={player ?? ""}
          required
        />
        <button type="submit"><span>Fetch player stats</span></button>
      </div>
      </div>
    </form>

    {error && <p class="error">Error: {error}</p>}

    {player && !error && games.length === 0 && (
      <p class="loading">No analyzed games found for <strong>{player}</strong>.</p>
    )}

  {timeline.length > 0 && (
  <div id="chartContainer">
    <div class="chart-header">
      <h2>Rating Timeline</h2>
      {bestGame && (
        <p class="date-range">
          {firstDate} — {lastDate} &middot; {games.length} games
        </p>
      )}
    </div>
    <canvas id="ratingChart"></canvas>
 <div class="chart-footer">
  <p id="range-info"></p>
  <button id="analyze-btn" style="display:none">Analyze period</button>
</div>
  </div>
)}

    

    {(bestGame || worstGame || timeline.length > 0) && (
      <div id="main-cards-row" class="cards-row">

        {bestGame && (
         <div class="result best">
  <h3>Best Game</h3>
  <strong
    data-val={bestGame.accuracy}
    data-decimals="1"
    data-suffix="%"
    data-color={bestGame.winner === "draw" ? "#6ab8cc" : bestGame.winner === bestGame.color ? "#5bb274" : "#e05a5a"}
    style={bestGame.winner === "draw" ? "color:#6ab8cc" : bestGame.winner === bestGame.color ? "color:#5bb274" : "color:#e05a5a"}
  >{bestGame.accuracy}%</strong>

  <div class="card-body">
    <div class="card-side">
      <p><span>Rating</span>  <b data-val={bestGame.rating} data-decimals="0" data-suffix="" data-color="#d8f5ff">{bestGame.rating}</b></p>
      <p><span>Color</span>   <b>{bestGame.color}</b></p>
      <p><span>Date</span>    <b>{new Date(bestGame.date).toLocaleDateString("en-GB")}</b></p>
      
    </div>
    <div class="card-divider"></div>
    <div class="card-side">
      <p class="side-label">Opponent</p>
      <p><span>Name</span>      <b>{bestGame.opponent.name}</b></p>
      <p><span>Rating</span>    <b data-val={bestGame.opponent.rating} data-decimals="0" data-suffix="" data-color="#d8f5ff">{bestGame.opponent.rating}</b></p>
      <p><span>Accuracy</span>  {bestGame.opponent.accuracy != null
        ? <b data-val={bestGame.opponent.accuracy} data-decimals="0" data-suffix="%" data-color="#d8f5ff">{bestGame.opponent.accuracy}%</b>
        : <b>N/A</b>}</p>
    </div>
  </div>

<div class="card-footer">
  <span class="result-label">Result:</span>
  <b class={bestGame.winner === "draw" ? "draw" : bestGame.winner === bestGame.color ? "win" : "loss"}>
    {getResult(bestGame)}
  </b>
  <a href={`https://lichess.org/${bestGame.id}`} target="_blank">View game →</a>
</div>
</div>
        )}

        {worstGame && (
          <div class="result worst">
  <h3>Worst Game</h3>
  <strong
    data-val={worstGame.accuracy}
    data-decimals="1"
    data-suffix="%"
    data-color={worstGame.winner === "draw" ? "#6ab8cc" : worstGame.winner === worstGame.color ? "#5bb274" : "#e05a5a"}
    style={worstGame.winner === "draw" ? "color:#6ab8cc" : worstGame.winner === worstGame.color ? "color:#5bb274" : "color:#e05a5a"}
  >{worstGame.accuracy.toFixed(1)}%</strong>

  <div class="card-body">
    <div class="card-side">
      
      <p><span>Rating</span>  <b data-val={worstGame.rating} data-decimals="0" data-suffix="" data-color="#d8f5ff">{worstGame.rating}</b></p>
      <p><span>Color</span>   <b>{worstGame.color}</b></p>
      <p><span>Date</span>    <b>{new Date(worstGame.date).toLocaleDateString("en-GB")}</b></p>
     
    </div>
    <div class="card-divider"></div>
    <div class="card-side">
      <p class="side-label">Opponent</p>
      <p><span>Name</span>      <b>{worstGame.opponent.name}</b></p>
      <p><span>Rating</span>    <b data-val={worstGame.opponent.rating} data-decimals="0" data-suffix="" data-color="#d8f5ff">{worstGame.opponent.rating}</b></p>
      <p><span>Accuracy</span>  {worstGame.opponent.accuracy != null
        ? <b data-val={worstGame.opponent.accuracy} data-decimals="0" data-suffix="%" data-color="#d8f5ff">{worstGame.opponent.accuracy}%</b>
        : <b>N/A</b>}</p>
    </div>
  </div>

<div class="card-footer">
  <span class="result-label">Result:</span>
  <b class={worstGame.winner === "draw" ? "draw" : worstGame.winner === worstGame.color ? "win" : "loss"}>
    {getResult(worstGame)}
  </b>
  <a href={`https://lichess.org/${worstGame.id}`} target="_blank">View game →</a>
</div></div>
        )}

      </div>
    )}

    {timeline.length > 0 && (
      <script define:vars={{ timelineData }} is:inline>
        window.__timelineData = timelineData;
      </script>
    )}

    {timeline.length > 0 && (
      <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    )}

    {timeline.length > 0 && (
      <script is:inline>
        (function () {
          var labels  = window.__timelineData.map(function (p) { return new Date(p.date).toLocaleDateString("en-GB"); });
          var ratings = window.__timelineData.map(function (p) { return p.rating; });
          var n       = labels.length;

          // ── Handle state ──────────────────────────────────────────────────
          var handleA  = 0;
          var handleB  = n - 1;
          var dragging = null; // 'A' | 'B' | null
          var graphInteracted = false;

          // ── Chart.js plugin — draws the two handles after every render ────
          // Returns the rendered x position (CSS px) of the i-th data point.
          // chart.getDatasetMeta(0).data[i].x is the v4-compatible way;
          // Chart.js applies the DPR scale to ctx internally, so these coords
          // are already in CSS-pixel space and can be used directly in ctx calls.
          function pointX(ch, idx) {
            return ch.getDatasetMeta(0).data[idx].x;
          }

          var COLOR_NORMAL   = "#ff8c00";
          var COLOR_INVERTED = "#ff8c00";

          var rangePlugin = {
            id: "rangeSelector",
            afterDraw: function (ch) {
              var ctx = ch.ctx;
              var ca  = ch.chartArea;
              var inv = handleA > handleB;
              var col = inv ? COLOR_INVERTED : COLOR_NORMAL;

              var xA  = pointX(ch, handleA);
              var xB  = pointX(ch, handleB);
              var lft = Math.min(xA, xB);
              var rgt = Math.max(xA, xB);

              ctx.save();

              // ── Region fill ───────────────────────────────────────────────
              ctx.fillStyle = inv
                ? "rgba(255, 140, 0, 0.18)"   // red tint outside handles
                : "rgba(255, 140, 0, 0.18)";  // orange tint between handles

              if (!inv) {
                ctx.fillRect(lft, ca.top, rgt - lft, ca.bottom - ca.top);
              } else {
                ctx.fillRect(ca.left, ca.top, lft - ca.left, ca.bottom - ca.top);
                ctx.fillRect(rgt,     ca.top, ca.right - rgt, ca.bottom - ca.top);
              }

              // ── Handles ───────────────────────────────────────────────────
              function drawHandle(x) {
                ctx.strokeStyle = col;
                ctx.lineWidth   = 2;
                ctx.beginPath();
                ctx.moveTo(x, ca.top);
                ctx.lineTo(x, ca.bottom);
                ctx.stroke();

                ctx.fillStyle = col;
                ctx.beginPath();
                ctx.arc(x, ca.top, 7, 0, Math.PI * 2);
                ctx.fill();
              }

              drawHandle(xA);
              drawHandle(xB);

              ctx.restore();
            },
          };

          // ── Create chart ──────────────────────────────────────────────────
          var ratingCanvas = document.getElementById("ratingChart");
          var chart = new Chart(ratingCanvas, {
            type: "line",
            plugins: [rangePlugin],
            data: {
              labels: labels,
              datasets: [{
                data: ratings,
                borderColor: "#4052A1",
                backgroundColor: "#4082A1",
                borderWidth: 2,
                tension: 0.35,
                pointRadius: 4,
                pointBackgroundColor: "#4052A1",
                pointBorderColor: "#4052A1",
                pointBorderWidth: 2,
                pointHoverRadius: 6,
                fill: true,
              }],
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              scales: {
                x: {
                  grid:   { color: "rgba(255,255,255,0.04)" },
                  ticks:  { color: "#7a8499", font: { size: 11 } },
                  border: { color: "rgba(255,255,255,0.06)" },
                },
                y: {
                  beginAtZero: false,
                  grid:   { color: "rgba(255,255,255,0.04)" },
                  ticks:  { color: "#7a8499", font: { size: 11 } },
                  border: { color: "rgba(255,255,255,0.06)" },
                },
              },
              plugins: {
                legend: { display: false },
                tooltip: {
                  backgroundColor: "#1e2535",
                  borderColor: "rgba(79,195,161,0.3)",
                  borderWidth: 1,
                  titleColor: "#e8eaf0",
                  bodyColor: "#4fc3a1",
                  padding: 10,
                },
              },
            },
          });

          // ── Pointer drag ──────────────────────────────────────────────────
          var HIT_CSS = 14; // hit-test radius in CSS pixels

          function getCssX(e) {
            return e.clientX - ratingCanvas.getBoundingClientRect().left;
          }

          // pointX() returns CSS pixels, same space as pointer events.
          function cssXToIdx(cssX) {
            var closest = 0, minDist = Infinity;
            for (var i = 0; i < n; i++) {
              var d = Math.abs(pointX(chart, i) - cssX);
              if (d < minDist) { minDist = d; closest = i; }
            }
            return closest;
          }

          function hitTest(cssX) {
            var dA = Math.abs(cssX - pointX(chart, handleA));
            var dB = Math.abs(cssX - pointX(chart, handleB));
            if (dA <= HIT_CSS && dA <= dB) return "A";
            if (dB <= HIT_CSS)             return "B";
            return null;
          }

          // ── Range info text ───────────────────────────────────────────────
          function updateRangeInfo() {
            var inv    = handleA > handleB;
            var idxMin = Math.min(handleA, handleB);
            var idxMax = Math.max(handleA, handleB);
            var count  = inv ? n - (idxMax - idxMin + 1) : idxMax - idxMin + 1;
            var el     = document.getElementById("range-info");

            if (inv) {
              el.innerHTML =
                "<b style='color:" + COLOR_INVERTED + "'>Inverted</b>" +
                " &mdash; outside " + labels[idxMin] + " &ndash; " + labels[idxMax] +
                " &middot; " + count + " games";
            } else {
              el.textContent =
                labels[idxMin] + " \u2013 " + labels[idxMax] + " \u00B7 " + count + " games";
            }

            document.getElementById("analyze-btn").style.display = "";
            if (graphInteracted) {
              var btn = document.getElementById("analyze-btn");
              btn.classList.remove("pulsing");
              void btn.offsetWidth;
              btn.classList.add("pulsing");
            }
          }

          updateRangeInfo();

          ratingCanvas.addEventListener("pointerdown", function (e) {
            var hit = hitTest(getCssX(e));
            if (!hit) return;
            e.preventDefault();
            graphInteracted = true;
            dragging = hit;
            ratingCanvas.setPointerCapture(e.pointerId);
            ratingCanvas.style.cursor = "grabbing";
          });

          ratingCanvas.addEventListener("pointermove", function (e) {
            var cssX = getCssX(e);
            if (!dragging) {
              ratingCanvas.style.cursor = hitTest(cssX) ? "ew-resize" : "";
              return;
            }
            var idx = cssXToIdx(cssX);
            if (dragging === "A") handleA = idx;
            else                  handleB = idx;
            chart.draw(); // redraw chart → triggers rangePlugin.afterDraw
            updateRangeInfo();
          });

          ratingCanvas.addEventListener("pointerup", function (e) {
            if (dragging) ratingCanvas.releasePointerCapture(e.pointerId);
            dragging = null;
            ratingCanvas.style.cursor = "";
          });

          // ── Analyze period ────────────────────────────────────────────────
          document.getElementById("analyze-btn").addEventListener("click", function () {
            var playerName = (new URLSearchParams(location.search).get("player") || "").toLowerCase();
            var allGames   = window.__allGames || [];
            var inv        = handleA > handleB;
            var idxMin     = Math.min(handleA, handleB);
            var idxMax     = Math.max(handleA, handleB);
            var startTs    = window.__timelineData[idxMin].date;
            var endTs      = window.__timelineData[idxMax].date;

            this.classList.remove("pulsing");

            var periodLabel = document.getElementById("period-label");
            if (periodLabel) periodLabel.textContent = labels[idxMin] + " – " + labels[idxMax];

            var filtered = allGames.filter(function (g) {
              var inRange = g.createdAt >= startTs && g.createdAt <= endTs;
              return inv ? !inRange : inRange;
            });

            var withAcc = filtered.map(function (g) {
              var isW = (g.white.user || "").toLowerCase() === playerName;
              var isB = (g.black.user || "").toLowerCase() === playerName;
              if (!isW && !isB) return null;
              var acc = isW ? g.white.accuracy : g.black.accuracy;
              if (acc === null) return null;
              return {
                id:       g.id,
                accuracy: acc,
                color:    isW ? "white" : "black",
                rating:   isW ? g.white.rating : g.black.rating,
                date:     g.createdAt,
                winner:   g.winner,
                opponent: isW
                  ? { name: g.black.user, rating: g.black.rating, accuracy: g.black.accuracy }
                  : { name: g.white.user, rating: g.white.rating, accuracy: g.white.accuracy },
              };
            }).filter(Boolean);

            var row = document.getElementById("main-cards-row");

            if (!withAcc.length) {
              row.innerHTML = "<p style='color:var(--text-muted);font-size:0.83rem'>No analyzed games in this period.</p>";
              return;
            }

            var best  = withAcc.reduce(function (a, b) { return b.accuracy > a.accuracy ? b : a; });
            var worst = withAcc.reduce(function (a, b) { return b.accuracy < a.accuracy ? b : a; });

            function resultInfo(g) {
              if (g.winner === "draw") return ["½ Draw", "draw"];
              return g.winner === g.color ? ["Win", "win"] : ["Loss", "loss"];
            }

            function animateNumber(el, end, decimals, duration, suffix, finalColor) {
              var startTime = null;
              el.textContent = "0" + suffix;
              function step(ts) {
                if (!startTime) startTime = ts;
                var progress = Math.min((ts - startTime) / duration, 1);
                var ease = 1 - Math.pow(1 - progress, 3);
                el.textContent = (end * ease).toFixed(decimals) + suffix;
                if (progress < 1) {
                  requestAnimationFrame(step);
                } else {
                  el.textContent = end.toFixed(decimals) + suffix;
                  el.animate([
                    { transform: "scale(1.05)", color: "#ffffff" },
                    { transform: "scale(1.0)",  color: finalColor }
                  ], { duration: 400, easing: "cubic-bezier(0.34, 1.56, 0.64, 1)", fill: "forwards" });
                }
              }
              requestAnimationFrame(step);
            }
            window.animateNumber = animateNumber;

            function resultColor(g) {
              if (g.winner === "draw") return "#6ab8cc";
              return g.winner === g.color ? "#5bb274" : "#e05a5a";
            }

            function cardHTML(g, label, cls) {
              var ri       = resultInfo(g);
              var accCol   = resultColor(g);
              var oppAccEl = g.opponent.accuracy != null
                ? '<b data-val="' + g.opponent.accuracy + '" data-decimals="0" data-suffix="%" data-color="#d8f5ff">0%</b>'
                : "<b>N/A</b>";
              return (
                '<div class="result ' + cls + '">' +
                  "<h3>" + label + "</h3>" +
                  '<strong data-val="' + g.accuracy.toFixed(1) + '" data-decimals="1" data-suffix="%" data-color="' + accCol + '">0%</strong>' +
                  '<div class="card-body">' +
                    '<div class="card-side">' +
                      '<p><span>Rating</span><b data-val="' + g.rating + '" data-decimals="0" data-suffix="" data-color="#d8f5ff">0</b></p>' +
                      "<p><span>Color</span><b>"  + g.color  + "</b></p>" +
                      "<p><span>Date</span><b>"   + new Date(g.date).toLocaleDateString("en-GB") + "</b></p>" +
                    "</div>" +
                    '<div class="card-divider"></div>' +
                    '<div class="card-side">' +
                      '<p class="side-label">Opponent</p>' +
                      "<p><span>Name</span><b>"     + (g.opponent.name || "?") + "</b></p>" +
                      '<p><span>Rating</span><b data-val="' + g.opponent.rating + '" data-decimals="0" data-suffix="" data-color="#d8f5ff">0</b></p>' +
                      "<p><span>Accuracy</span>" + oppAccEl + "</p>" +
                    "</div>" +
                  "</div>" +
                  '<div class="card-footer">' +
                    '<span class="result-label">Result:</span>' +
                    '<b class="' + ri[1] + '">' + ri[0] + "</b>" +
                    '<a href="https://lichess.org/' + g.id + '" target="_blank">View game \u2192</a>' +
                  "</div>" +
                "</div>"
              );
            }

            row.innerHTML = cardHTML(best, "Highest accurancy", "best") +
                            cardHTML(worst, "Lowest accurancy", "worst");
            row.querySelectorAll("[data-val]").forEach(function (el, i) {
              setTimeout(function () {
                animateNumber(
                  el,
                  parseFloat(el.dataset.val),
                  parseInt(el.dataset.decimals),
                  i < 2 ? 1100 : 850,
                  el.dataset.suffix,
                  el.dataset.color
                );
              }, i * 120);
            });
            row.scrollIntoView({ behavior: "smooth", block: "nearest" });
          });

        })();
      </script>
      <script define:vars={{ allGamesData }} is:inline>
  window.__allGames = allGamesData;
</script>
    )}

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('[data-val]').forEach(function (el, i) {
        setTimeout(function () {
          if (typeof window.animateNumber !== 'function') return;
          window.animateNumber(
            el,
            parseFloat(el.dataset.val),
            parseInt(el.dataset.decimals),
            i < 2 ? 1100 : 850,
            el.dataset.suffix,
            el.dataset.color
          );
        }, i * 120);
      });
    });
  </script>
  </body>
</html>